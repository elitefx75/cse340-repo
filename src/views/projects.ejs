<%- include('partials/header') %>

    <main class="projects-page">
        <section class="projects-hero">
            <p class="projects-subtitle">Showing the next <%= Array.isArray(projects) ? projects.length : 0 %> upcoming
                    service opportunities:</p>
            <h1>
                <%= title %>
            </h1>
            <p class="projects-description">Connect with volunteer-powered service projects that support local
                communities and build brighter futures.</p>
        </section>

        <% const projectsList=Array.isArray(projects) ? projects : []; %>

            <section class="project-grid-section">
                <% if (projectsList.length===0) { %>
                    <p>No projects found.</p>
                    <% } else { %>
                        <div class="project-grid">
                            <% projectsList.forEach(project=> { %>
                                <article class="project-card">
                                    <h3 class="project-title">
                                        <a href="/project/<%= project.project_id %>">
                                            <%= project.title %>
                                        </a>
                                    </h3>

                                    <p class="project-sponsor">
                                        Sponsored by
                                        <a href="/organization/<%= project.organization_id %>">
                                            <%= project.organization_name %>
                                        </a>
                                    </p>

                                    <div class="project-actions">
                                        <a class="btn-small" href="/project/<%= project.project_id %>">View Details</a>
                                        <a class="btn-small btn-secondary" href="#">Add a New Service Project</a>
                                    </div>
                                </article>
                                <% }) %>
                        </div>
                        <% } %>
            </section>
    </main>

    <%- include('partials/footer') %>