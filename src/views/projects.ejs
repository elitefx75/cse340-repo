<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <p>
            Discover service projects designed to make a positive impact in communities around the region.
            These projects connect volunteers with meaningful work across a range of focus areas.
        </p>

        <% const projectsList=Array.isArray(projects) ? projects : []; %>

            <section>
                <h2>Upcoming Service Projects</h2>

                <% if (projectsList.length===0) { %>
                    <p>No projects found.</p>
                    <% } else { %>
                        <div class="project-list">
                            <% projectsList.forEach(project=> { %>
                                <article class="project-card">
                                    <h3>
                                        <a href="/project/<%= project.project_id %>">
                                            <%= project.title %>
                                        </a>
                                    </h3>

                                    <p>
                                        <strong>Organization:</strong>
                                        <a href="/organization/<%= project.organization_id %>">
                                            <%= project.organization_name %>
                                        </a>
                                    </p>

                                    <p>
                                        <%= project.description %>
                                    </p>

                                    <p>
                                        <strong>Date:</strong>
                                        <%= project.date ? new Date(project.date).toDateString() : '' %>
                                    </p>

                                    <p>
                                        <strong>Location:</strong>
                                        <%= project.location %>
                                    </p>
                                </article>
                                <% }) %>
                        </div>
                        <% } %>
            </section>

            <section>
                <h2>How to Get Involved</h2>
                <p>
                    Browse projects by category, choose one that matches your interests, and join other volunteers
                    to make a real difference. Every project helps build stronger communities.
                </p>
            </section>
    </main>

    <%- include('partials/footer') %>